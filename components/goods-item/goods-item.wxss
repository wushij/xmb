.goods-item {
  display: flex;
  align-items: flex-start; /* 保留原有顶部对齐逻辑 */
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
  position: relative;
}

/* 商品图片样式（保留不变） */
.goods-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  z-index: 1;
}

/* 图片兜底占位符（保留不变） */
.goods-img-placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  background-color: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #666;
  position: absolute;
  left: 0;
  top: 20rpx;
  z-index: 0;
}

/* 商品信息（保留不变） */
.goods-info {
  flex: 1;
}
.goods-name {
  font-size: 32rpx;
  font-weight: 500;
  margin-bottom: 10rpx;
}
.goods-stock {
  font-size: 24rpx;
  color: #e64340;
  margin-bottom: 10rpx;
}
.price-area {
  display: flex;
  align-items: center;
  gap: 10rpx;
}
.now-price {
  font-size: 30rpx;
  color: #e64340;
  font-weight: bold;
}
.old-price {
  font-size: 24rpx;
  color: #999;
  text-decoration: line-through;
}
.discount {
  font-size: 22rpx;
  color: #fff;
  background-color: #e64340;
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
}

/* 加号按钮（核心修改：去掉硬编码margin-top，用align-self控制对齐） */
.add-btn {
  width: 60rpx;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  border: 1rpx solid #e64340;
  color: #e64340;
  border-radius: 50%;
  font-size: 36rpx;
  align-self: flex-start;
}

/* 已售罄按钮样式 */
.add-btn.disabled {
  border-color: #ccc;
  color: #ccc;
  background-color: #f5f5f5;
}

/* 已售罄文字样式 */
.goods-stock.sold-out {
  color: #999;
  font-size: 26rpx;
  font-weight: 500;
}