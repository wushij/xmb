/* ========== 全局容器 ========== */
.address-container {
  width: 100%;
  min-height: 100vh;
  background: linear-gradient(180deg, #f5f7fa 0%, #fff 100%);
  padding-bottom: 40rpx;
  box-sizing: border-box;
  position: relative;
}

/* ========== 顶部渐变背景 ========== */
.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 400rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 0 0 50rpx 50rpx;
  overflow: hidden;
}

.deco-circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
}

.deco-circle-1 {
  width: 300rpx;
  height: 300rpx;
  top: -100rpx;
  right: -50rpx;
}

.deco-circle-2 {
  width: 200rpx;
  height: 200rpx;
  bottom: -50rpx;
  left: 30rpx;
}

/* ========== 页面标题 ========== */
.page-title {
  position: relative;
  padding: 80rpx 40rpx 60rpx;
  text-align: center;
  z-index: 10;
}

.title-text {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
  letter-spacing: 4rpx;
}

.title-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  letter-spacing: 2rpx;
}

/* ========== 编辑表单卡片 ========== */
.edit-form-card {
  position: relative;
  margin: 0 30rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.15);
  z-index: 10;
}

.card-title {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 40rpx;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.title-icon {
  margin-right: 12rpx;
  font-size: 36rpx;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 28rpx 20rpx;
  margin-bottom: 16rpx;
  background: linear-gradient(135deg, #f8f9ff 0%, #fff 100%);
  border-radius: 16rpx;
  border: 2rpx solid #f0f0ff;
}

.form-left {
  display: flex;
  align-items: center;
  width: 200rpx;
}

.form-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #666;
}

.picker-text {
  flex: 1;
  font-size: 28rpx;
  color: #666;
}

.placeholder-text {
  color: #999;
}

.switch-item {
  justify-content: space-between;
  background: transparent;
  border: none;
  margin-top: 20rpx;
}

.form-btn-wrap {
  display: flex;
  gap: 20rpx;
  margin-top: 50rpx;
}

.cancel-btn,
.save-btn {
  flex: 1;
  height: 90rpx;
  line-height: 90rpx;
  border-radius: 45rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
}

.cancel-btn {
  background: #f5f5f5;
  color: #666;
}

.save-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
}

/* ========== 新增按钮卡片 ========== */
.add-btn-card {
  position: relative;
  margin: 0 30rpx 24rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  border: 3rpx dashed #667eea;
  border-radius: 24rpx;
  font-size: 30rpx;
  color: #667eea;
  font-weight: 500;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.1);
  z-index: 10;
}

.add-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

/* ========== 地址列表 ========== */
.address-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 0 30rpx;
}

.address-item-card {
  position: relative;
  background: #fff;
  padding: 32rpx 28rpx;
  border-radius: 24rpx;
  box-shadow: 0 6rpx 24rpx rgba(102, 126, 234, 0.12);
  z-index: 10;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.address-item-card:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.15);
}

/* 默认地址卡片高亮 */
.address-item-card:has(.default-badge) {
  border-color: rgba(102, 126, 234, 0.4);
  box-shadow: 0 6rpx 24rpx rgba(102, 126, 234, 0.2);
}

/* 默认标签 */
.default-badge {
  position: absolute;
  top: 0;
  right: 24rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 22rpx;
  padding: 10rpx 24rpx;
  border-radius: 0 0 16rpx 16rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.address-content {
  margin-bottom: 20rpx;
  padding-top: 16rpx;
}

.name-phone {
  display: flex;
  align-items: baseline;
  gap: 24rpx;
  margin-bottom: 16rpx;
}

.name-phone .name {
  font-size: 34rpx;
  color: #333;
  font-weight: 600;
}

.name-phone .phone {
  font-size: 28rpx;
  color: #999;
  font-weight: 400;
}

.address-detail {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.region {
  font-size: 26rpx;
  color: #666;
  display: block;
}

.detail {
  font-size: 28rpx;
  color: #555;
  display: block;
  line-height: 1.5;
}

/* 操作按钮区域 */
.address-op {
  display: flex;
  gap: 16rpx;
  justify-content: flex-end;
  padding-top: 20rpx;
  border-top: 2rpx solid #f5f5f5;
  margin-top: 20rpx;
}

.address-op button {
  padding: 16rpx 32rpx;
  font-size: 26rpx;
  border-radius: 32rpx;
  font-weight: 500;
  border: none;
  white-space: nowrap;
  min-width: auto;
}

.default-btn {
  background: linear-gradient(135deg, #f0f3ff 0%, #e8ecff 100%);
  border: 2rpx solid #667eea !important;
  color: #667eea;
}

.default-btn:active {
  background: linear-gradient(135deg, #e8ecff 0%, #dfe4ff 100%);
}

.delete-btn {
  background: linear-gradient(135deg, #f5f5f5 0%, #ebebeb 100%);
  color: #999;
  border: none !important;
}

.delete-btn:active {
  background: linear-gradient(135deg, #ebebeb 0%, #e0e0e0 100%);
  color: #666;
}

/* 空状态 */
.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  position: relative;
  z-index: 10;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  opacity: 0.8;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.empty-hint {
  font-size: 26rpx;
  color: #bbb;
}

/* 选择模式样式 */
.address-item-card.selectable {
  cursor: pointer;
}

.address-item-card.selectable:active {
  background: #fafafa;
}
