<view class="address-container">
  <!-- 顶部渐变背景区 -->
  <view class="header-bg">
    <view class="deco-circle deco-circle-1"></view>
    <view class="deco-circle deco-circle-2"></view>
  </view>
  
  <!-- 页面标题 -->
  <view class="page-title">
    <text class="title-text">收货地址</text>
    <text class="title-subtitle">管理您的收货地址</text>
  </view>

  <!-- ========== 编辑/新增表单区域 ========== -->
  <view class="edit-form-card" wx:if="{{isEditMode}}">
    <view class="card-title">
      <text class="title-icon">📝</text>
      <text>{{addressForm.id ? '编辑地址' : '新增地址'}}</text>
    </view>
    
    <view class="form-item">
      <view class="form-left">
        <text class="form-icon">👤</text>
        <text class="form-label">收货人</text>
      </view>
      <input class="form-input" placeholder="请输入姓名" value="{{addressForm.name}}" data-field="name" bindinput="onInputChange"></input>
    </view>

    <view class="form-item">
      <view class="form-left">
        <text class="form-icon">📱</text>
        <text class="form-label">手机号</text>
      </view>
      <input class="form-input" type="number" placeholder="11位手机号" value="{{addressForm.phone}}" data-field="phone" bindinput="onInputChange"></input>
    </view>

    <view class="form-item">
      <view class="form-left">
        <text class="form-icon">📍</text>
        <text class="form-label">省市区</text>
      </view>
      <picker mode="region" value="{{[addressForm.province, addressForm.city, addressForm.district]}}" bindchange="onRegionChange">
        <view class="picker-text">
          {{addressForm.province}}{{addressForm.city}}{{addressForm.district}}
          <text wx:if="{{!addressForm.province}}" class="placeholder-text">请选择</text>
        </view>
      </picker>
    </view>

    <view class="form-item">
      <view class="form-left">
        <text class="form-icon">🏠</text>
        <text class="form-label">详细地址</text>
      </view>
      <input class="form-input" placeholder="街道/门牌号" value="{{addressForm.detail}}" data-field="detail" bindinput="onInputChange"></input>
    </view>

    <view class="form-item switch-item">
      <view class="form-left">
        <text class="form-icon">⭐</text>
        <text class="form-label">设为默认</text>
      </view>
      <switch checked="{{addressForm.isDefault}}" bindchange="onDefaultChange" color="#667eea"></switch>
    </view>

    <view class="form-btn-wrap">
      <button class="cancel-btn" bindtap="cancelEdit">取消</button>
      <button class="save-btn" bindtap="saveAddress">{{addressForm.id ? '保存修改' : '新增地址'}}</button>
    </view>
  </view>

  <!-- ========== 地址列表区域 ========== -->
  <view class="list-area" wx:else>
    <!-- 新增按钮 -->
    <view class="add-btn-card" bindtap="enterEditMode">
      <text class="add-icon">➕</text>
      <text>新增收货地址</text>
    </view>

    <!-- 地址列表 -->
    <view class="address-list" wx:if="{{addressList.length > 0}}">
      <view class="address-item-card {{isSelectMode ? 'selectable' : ''}}" wx:for="{{addressList}}" wx:key="id">
        <view class="default-badge" wx:if="{{item.isDefault}}">
          <text>⭐ 默认</text>
        </view>
        <view class="address-content" bindtap="{{isSelectMode ? 'selectAddress' : 'enterEditMode'}}" data-address="{{item}}">
          <view class="name-phone">
            <text class="name">{{item.name}}</text>
            <text class="phone">{{item.phone}}</text>
          </view>
          <view class="address-detail">
            <text class="region">📍 {{item.province}}{{item.city}}{{item.district}}</text>
            <text class="detail">{{item.detail}}</text>
          </view>
        </view>
        <view class="address-op" wx:if="{{!isSelectMode}}">
          <button class="delete-btn" bindtap="deleteAddress" data-id="{{item.id}}">🗑️ 删除</button>
          <button class="default-btn" wx:if="{{!item.isDefault}}" bindtap="setDefaultAddress" data-id="{{item.id}}">⭐ 设为默认</button>
        </view>
      </view>
    </view>

    <!-- 空列表提示 -->
    <view class="empty-tip" wx:elif="{{hasLogin}}">
      <text class="empty-icon">📭</text>
      <text class="empty-text">暂无收货地址</text>
      <text class="empty-hint">点击上方按钮添加新地址</text>
    </view>
  </view>
</view>