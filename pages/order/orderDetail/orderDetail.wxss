.container {
  padding: 20rpx;
  padding-bottom: 140rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 300rpx;
  color: #999;
}

/* 订单状态 */
.status-section {
  background: linear-gradient(135deg, #ff6b6b 0%, #e63946 100%);
  border-radius: 16rpx;
  padding: 40rpx;
  text-align: center;
  margin-bottom: 20rpx;
}

.status-icon {
  font-size: 60rpx;
  margin-bottom: 16rpx;
}

.status-text {
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
}

/* 通用section样式 */
.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #e63946;
}

/* 收货地址 */
.address-section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.address-content {
  background-color: #f9f9f9;
  border-radius: 12rpx;
  padding: 20rpx;
}

/* 配送方式标签 */
.delivery-type-tag {
  display: inline-flex;
  align-items: center;
  background-color: #fff3e0;
  color: #ff9800;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  margin-bottom: 16rpx;
  font-size: 24rpx;
}

.delivery-type-tag.delivery {
  background-color: #e3f2fd;
  color: #2196f3;
}

.tag-icon {
  margin-right: 8rpx;
  font-size: 28rpx;
}

.tag-text {
  font-weight: bold;
}

.receiver {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.receiver .name {
  font-size: 30rpx;
  font-weight: bold;
  margin-right: 20rpx;
}

.receiver .phone {
  font-size: 26rpx;
  color: #666;
}

.address {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

/* 自提信息区域 */
.pickup-section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.pickup-content {
  background-color: #fff8f0;
  border-radius: 12rpx;
  padding: 20rpx;
}

.pickup-info {
  margin-top: 16rpx;
}

.pickup-row {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #ffe8d6;
}

.pickup-row:last-of-type {
  border-bottom: none;
}

.pickup-label {
  font-size: 26rpx;
  color: #999;
  width: 140rpx;
  flex-shrink: 0;
}

.pickup-value {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.pickup-tip {
  margin-top: 20rpx;
  padding: 16rpx;
  background-color: #fff3e0;
  border-radius: 8rpx;
  display: flex;
  align-items: flex-start;
}

.tip-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.tip-text {
  font-size: 24rpx;
  color: #ff9800;
  line-height: 1.5;
}

/* 商品列表 */
.goods-section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.goods-list {
  border-top: 1rpx solid #eee;
  padding-top: 20rpx;
}

.goods-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.goods-item:last-child {
  border-bottom: none;
}

.goods-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
  background-color: #f5f5f5;
}

.goods-info {
  flex: 1;
}

.goods-name {
  font-size: 28rpx;
  color: #333;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.goods-price-row {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
}

.goods-price {
  font-size: 26rpx;
  color: #e63946;
}

.goods-num {
  font-size: 24rpx;
  color: #999;
  margin-left: 16rpx;
}

.goods-total {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

/* 价格明细 */
.price-section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  font-size: 28rpx;
  color: #666;
}

.price-row.total {
  border-top: 1rpx solid #eee;
  margin-top: 12rpx;
  padding-top: 20rpx;
}

.total-price {
  font-size: 36rpx;
  color: #e63946;
  font-weight: bold;
}

.free {
  color: #52c41a;
}

/* 订单信息 */
.info-section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 12rpx 0;
  font-size: 26rpx;
}

.info-row .label {
  color: #999;
  width: 160rpx;
  flex-shrink: 0;
}

.info-row .value {
  color: #333;
  text-align: right;
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.copy-btn {
  margin-left: 16rpx;
  padding: 4rpx 16rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  font-size: 22rpx;
  color: #666;
}

/* 操作按钮 */
.action-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  padding: 20rpx 30rpx;
  display: flex;
  gap: 20rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.action-section button {
  flex: 1;
  font-size: 28rpx;
  padding: 20rpx 0;
  border-radius: 40rpx;
  border: none;
}

.btn-default {
  background-color: #f5f5f5;
  color: #666;
}

.btn-cancel {
  background-color: #fff;
  color: #666;
  border: 2rpx solid #ddd !important;
}

.btn-primary {
  background-color: #e63946;
  color: #fff;
}

.btn-warning {
  background-color: #ff9500;
  color: #fff;
}
