<view class="container">
  <!-- 加载中 -->
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <block wx:if="{{order && !loading}}">
    <!-- 订单状态 -->
    <view class="status-section">
      <view class="status-icon">
        <text class="iconfont" wx:if="{{order.statusNum === 0}}">⏳</text>
        <text class="iconfont" wx:elif="{{order.statusNum === 1}}">📦</text>
        <text class="iconfont" wx:elif="{{order.statusNum === 2}}">🚚</text>
        <text class="iconfont" wx:elif="{{order.statusNum === 3}}">✅</text>
        <text class="iconfont" wx:elif="{{order.statusNum === 4}}">❌</text>
        <text class="iconfont" wx:else>💰</text>
      </view>
      <view class="status-text">{{order.status}}</view>
    </view>

    <!-- 收货地址/自提信息 -->
    <view class="address-section" wx:if="{{order.deliveryType === 0}}">
      <view class="section-title">收货信息</view>
      <view class="address-content">
        <view class="delivery-type-tag delivery">
          <text class="tag-icon">🚚</text>
          <text class="tag-text">配送到家</text>
        </view>
        <view class="receiver">
          <text class="name">{{order.receiverName}}</text>
          <text class="phone">{{order.receiverPhone}}</text>
        </view>
        <view class="address">{{order.address}}</view>
      </view>
    </view>

    <!-- 自提信息 -->
    <view class="pickup-section" wx:if="{{order.deliveryType === 1}}">
      <view class="section-title">取货信息</view>
      <view class="pickup-content">
        <view class="delivery-type-tag">
          <text class="tag-icon">🏪</text>
          <text class="tag-text">到店自提</text>
        </view>
        <view class="pickup-info">
          <view class="pickup-row">
            <text class="pickup-label">取货人</text>
            <text class="pickup-value">{{order.receiverName}}</text>
          </view>
          <view class="pickup-row">
            <text class="pickup-label">联系电话</text>
            <text class="pickup-value">{{order.receiverPhone}}</text>
          </view>
          <view class="pickup-row">
            <text class="pickup-label">取货地址</text>
            <text class="pickup-value">{{order.pickupAddress}}</text>
          </view>
          <view class="pickup-tip">
            <text class="tip-icon">💡</text>
            <text class="tip-text">订单支付成功后,请凭订单到门店取货</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 商品列表 -->
    <view class="goods-section">
      <view class="section-title">商品信息</view>
      <view class="goods-list">
        <view class="goods-item" wx:for="{{order.goodsList}}" wx:key="goodsId">
          <image class="goods-img" src="{{item.imgUrl}}" mode="aspectFill"></image>
          <view class="goods-info">
            <text class="goods-name">{{item.name}}</text>
            <view class="goods-price-row">
              <text class="goods-price">¥{{item.price}}</text>
              <text class="goods-num">x{{item.num}}</text>
            </view>
          </view>
          <view class="goods-total">¥{{item.totalPrice}}</view>
        </view>
      </view>
    </view>

    <!-- 价格明细 -->
    <view class="price-section">
      <view class="section-title">价格明细</view>
      <view class="price-row">
        <text>商品金额</text>
        <text>¥{{order.goodsPrice}}</text>
      </view>
      <view class="price-row" wx:if="{{order.deliveryType === 0 && order.deliveryFee > 0}}">
        <text>配送费</text>
        <text>¥{{order.deliveryFee}}</text>
      </view>
      <view class="price-row" wx:if="{{order.deliveryType === 0 && order.deliveryFee == 0}}">
        <text>配送费</text>
        <text class="free">免配送费</text>
      </view>
      <view class="price-row" wx:if="{{order.deliveryType === 1}}">
        <text>自提</text>
        <text class="free">免配送费</text>
      </view>
      <view class="price-row total">
        <text>订单合计</text>
        <text class="total-price">¥{{order.totalPrice}}</text>
      </view>
    </view>

    <!-- 订单信息 -->
    <view class="info-section">
      <view class="section-title">订单信息</view>
      <view class="info-row">
        <text class="label">订单编号</text>
        <view class="value">
          <text>{{order.orderNo}}</text>
          <text class="copy-btn" bindtap="copyOrderNo">复制</text>
        </view>
      </view>
      <view class="info-row">
        <text class="label">下单时间</text>
        <text class="value">{{order.createTime}}</text>
      </view>
      <view class="info-row" wx:if="{{order.payTime}}">
        <text class="label">支付时间</text>
        <text class="value">{{order.payTime}}</text>
      </view>
      <view class="info-row" wx:if="{{order.deliveryTime}}">
        <text class="label">发货时间</text>
        <text class="value">{{order.deliveryTime}}</text>
      </view>
      <view class="info-row" wx:if="{{order.receiveTime}}">
        <text class="label">收货时间</text>
        <text class="value">{{order.receiveTime}}</text>
      </view>
      <view class="info-row">
        <text class="label">订单备注</text>
        <text class="value">{{order.remark}}</text>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-section">
      <!-- 待付款 -->
      <block wx:if="{{order.statusNum === 0}}">
        <button class="btn-cancel" bindtap="cancelOrder">取消订单</button>
        <button class="btn-primary" bindtap="payOrder">立即付款</button>
      </block>
      <!-- 待发货 -->
      <block wx:elif="{{order.statusNum === 1}}">
        <button class="btn-default" bindtap="contactService">联系客服</button>
        <button class="btn-warning" bindtap="applyRefund">申请退款</button>
      </block>
      <!-- 待收货 -->
      <block wx:elif="{{order.statusNum === 2}}">
        <button class="btn-default" bindtap="contactService">联系客服</button>
        <button class="btn-primary" bindtap="confirmReceive">确认收货</button>
      </block>
      <!-- 其他状态 -->
      <block wx:else>
        <button class="btn-default" bindtap="contactService">联系客服</button>
      </block>
    </view>
  </block>
</view>
