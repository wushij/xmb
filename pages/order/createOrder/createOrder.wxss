/* ========== 全局容器 ========== */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f5f7fa 0%, #fff 100%);
  padding-bottom: 220rpx;
  position: relative;
}

/* ========== 顶部渐变背景 ========== */
.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 400rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 0 0 50rpx 50rpx;
  overflow: hidden;
  z-index: 0;
}

.deco-circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
}

.deco-circle-1 {
  width: 300rpx;
  height: 300rpx;
  top: -100rpx;
  right: -50rpx;
}

.deco-circle-2 {
  width: 200rpx;
  height: 200rpx;
  bottom: -50rpx;
  left: 30rpx;
}

/* ========== 页面标题 ========== */
.page-title {
  position: relative;
  padding: 80rpx 40rpx 60rpx;
  text-align: center;
  z-index: 10;
}

.title-text {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
  letter-spacing: 4rpx;
}

.title-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  letter-spacing: 2rpx;
}

/* ========== 支付操作栏 ========== */
.pay-action-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 30rpx;
  z-index: 100;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
}

.pay-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.pay-text {
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
}

.pay-price {
  color: #fff;
  font-size: 40rpx;
  font-weight: bold;
}

.pay-btns {
  display: flex;
  gap: 20rpx;
}

.btn-cancel {
  flex: 1;
  background-color: rgba(255, 255, 255, 0.2);
  color: #fff;
  font-size: 28rpx;
  padding: 20rpx 0;
  border-radius: 50rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
  font-weight: 500;
}

.btn-pay {
  flex: 1;
  background-color: #fff;
  color: #667eea;
  font-size: 28rpx;
  font-weight: bold;
  padding: 20rpx 0;
  border-radius: 50rpx;
  border: none;
}

/* ========== 订单内容区域 ========== */
.order-content {
  position: relative;
  z-index: 10;
  padding: 0 24rpx;
}

/* ========== 卡片通用样式 ========== */
.address-card,
.delivery-card,
.goods-card,
.remark-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 6rpx 24rpx rgba(102, 126, 234, 0.12);
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.card-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

/* ========== 收货地址卡片 ========== */
.address-card {
  position: relative;
}

.address-info {
  flex: 1;
}

.address-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.address-header .name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-right: 20rpx;
}

.address-header .phone {
  font-size: 28rpx;
  color: #666;
}

.address-detail {
  font-size: 26rpx;
  color: #999;
  line-height: 1.6;
}

.no-address {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: #999;
  font-size: 28rpx;
}

.no-address-icon {
  font-size: 32rpx;
  color: #667eea;
}

.arrow {
  color: #ccc;
  font-size: 40rpx;
  font-weight: 300;
  margin-left: 20rpx;
}

/* ========== 配送方式选择 ========== */
.delivery-type-options {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.delivery-type-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border: 2rpx solid #f0f0f0;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #fafafa 0%, #fff 100%);
  transition: all 0.3s;
}

.delivery-type-item.active {
  border-color: #667eea;
  background: linear-gradient(135deg, #f8f9ff 0%, #fff 100%);
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.2);
}

.type-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #f0f3ff 0%, #e8ecff 100%);
  border-radius: 16rpx;
  margin-right: 20rpx;
}

.delivery-type-item.active .type-icon-wrap {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.type-icon {
  font-size: 40rpx;
}

.type-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.type-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.type-desc {
  font-size: 24rpx;
  color: #999;
}

.type-radio {
  width: 44rpx;
  height: 44rpx;
  border: 3rpx solid #ddd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
}

.type-radio.checked {
  border-color: #667eea;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.type-radio.checked text {
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
}

/* ========== 商品清单 ========== */
.goods-list {
  border-top: none;
  padding-top: 0;
}

.goods-item {
  position: relative;
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.goods-item:last-child {
  border-bottom: none;
}

.goods-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  background-color: #f5f5f5;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.goods-img-placeholder {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #fff;
  font-weight: bold;
}

.goods-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.goods-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.goods-price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.goods-price {
  font-size: 32rpx;
  color: #e63946;
  font-weight: bold;
}

.goods-num {
  font-size: 26rpx;
  color: #999;
}

/* ========== 配送费信息 ========== */
.delivery-info {
  margin-top: 20rpx;
  padding: 20rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #fff5f5 0%, #fff 100%);
  border: 2rpx solid #ffe8e8;
}

.delivery-fee-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.delivery-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.delivery-value {
  font-size: 28rpx;
  color: #e63946;
  font-weight: bold;
}

.free-text {
  color: #52c41a;
}

.delivery-tip {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #ff9500;
  background: linear-gradient(135deg, #fff9e6 0%, #fff 100%);
  padding: 12rpx 16rpx;
  border-radius: 12rpx;
  border: 1rpx solid #ffe7ba;
}

.delivery-tip.free {
  color: #52c41a;
  background: linear-gradient(135deg, #f6ffed 0%, #fff 100%);
  border-color: #d9f7be;
}

.delivery-info.self-pickup {
  background: linear-gradient(135deg, #f0f9ff 0%, #fff 100%);
  border-color: #d6f4ff;
}

/* ========== 备注卡片 ========== */
.remark-card {
  margin-bottom: 0;
}

.remark-input {
  width: 100%;
  height: 150rpx;
  margin-top: 16rpx;
  padding: 20rpx;
  font-size: 28rpx;
  border: 2rpx solid #f0f0f0;
  border-radius: 12rpx;
  box-sizing: border-box;
  background: linear-gradient(135deg, #fafafa 0%, #fff 100%);
  transition: all 0.3s;
}

.remark-input:focus {
  border-color: #667eea;
  background: #fff;
}

/* ========== 底部结算栏 ========== */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  min-height: 120rpx;
  background: #fff;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
  z-index: 99;
}

.price-detail {
  width: 100%;
  display: flex;
  gap: 20rpx;
  margin-bottom: 10rpx;
  font-size: 24rpx;
  color: #666;
}

.price-row {
  display: flex;
  align-items: center;
}

.price-row.free {
  color: #52c41a;
}

.total-price {
  flex: 1;
  font-size: 28rpx;
}

.total-price .price {
  font-size: 40rpx;
  color: #e63946;
  font-weight: bold;
}

.submit-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 30rpx;
  padding: 20rpx 50rpx;
  border-radius: 50rpx;
  border: none;
  z-index: 100;
  margin-left: 20rpx;
  font-weight: 600;
  box-shadow: 0 6rpx 20rpx rgba(102, 126, 234, 0.4);
}

.submit-btn.disabled {
  background: #e0e0e0;
  color: #999;
  box-shadow: none;
}
