<view class="allorder-container">
  <!-- 顶部紫色渐变背景区 -->
  <view class="header-bg">
    <view class="deco-circle deco-circle-1"></view>
    <view class="deco-circle deco-circle-2"></view>
  </view>
  
  <!-- 页面标题 -->
  <view class="page-title">
    <text class="title-text">全部订单</text>
    <text class="title-subtitle">查看您的所有订单记录</text>
  </view>

  <!-- 订单列表 -->
  <view class="order-list">
    <!-- 空状态提示 -->
    <view class="empty-section" wx:if="{{orderList.length === 0}}">
      <view class="empty-icon">📭</view>
      <text class="empty-title">暂无订单记录</text>
      <text class="empty-hint">快去选购心仪的商品吧~</text>
      <view class="empty-btn" bindtap="goShopping">去逛逛</view>
    </view>

    <!-- 订单卡片 -->
    <view class="order-card" wx:for="{{orderList}}" wx:key="orderId">
      <!-- 订单头部 -->
      <view class="order-header">
        <view class="order-no-wrap">
          <text class="order-label">订单编号</text>
          <text class="order-no">{{item.orderNo}}</text>
        </view>
        <view class="order-status-wrap" style="background: {{getStatusColor(item.status)}}20; color: {{getStatusColor(item.status)}}">
          <text class="status-dot" style="background: {{getStatusColor(item.status)}}"></text>
          <text class="status-text">{{item.status}}</text>
        </view>
      </view>

      <!-- 商品列表 -->
      <view class="goods-container">
        <view class="goods-item" wx:for="{{item.goodsList}}" wx:for-item="goods" wx:for-index="idx" wx:key="goodsId">
          <image src="{{goods.imgUrl}}" class="goods-img" mode="aspectFill"></image>
          <view class="goods-info">
            <text class="goods-name">{{goods.name}}</text>
            <view class="goods-price-row">
              <text class="goods-price">¥{{goods.nowPrice}}</text>
              <text class="goods-num">x{{goods.num}}</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 配送费信息 -->
      <view class="delivery-info" wx:if="{{item.deliveryType === 0}}">
        <view class="delivery-left">
          <text class="delivery-icon">🚚</text>
          <text class="delivery-label">配送费</text>
        </view>
        <text class="delivery-free" wx:if="{{item.deliveryFee == 0 || item.isFreeDelivery}}">免配送费</text>
        <text class="delivery-fee" wx:else>¥{{item.deliveryFee || 3}}</text>
      </view>

      <!-- 订单底部 -->
      <view class="order-footer">
        <view class="order-info">
          <view class="info-row">
            <text class="info-icon">🕐</text>
            <text class="order-time">{{item.createTime}}</text>
          </view>
          <view class="total-row">
            <text class="total-label">订单合计</text>
            <text class="total-price">¥{{item.totalPrice}}</text>
          </view>
        </view>
        
        <!-- 操作按钮区域 -->
        <view class="order-op">
          <!-- 待付款订单 -->
          <block wx:if="{{item.status === '待支付'}}">
            <button class="op-btn detail-btn" bindtap="viewDetail" data-orderid="{{item.orderId}}">查看详情</button>
            <button class="op-btn pay-btn" bindtap="payOrder" data-orderid="{{item.orderId}}" data-price="{{item.totalPrice}}">立即付款</button>
          </block>
          <!-- 待发货订单 -->
          <block wx:elif="{{item.status === '商家备货中'}}">
            <button class="op-btn detail-btn" bindtap="viewDetail" data-orderid="{{item.orderId}}">查看详情</button>
            <button class="op-btn refund-btn" bindtap="applyRefund" data-orderid="{{item.orderId}}" data-price="{{item.totalPrice}}">申请退款</button>
          </block>
          <!-- 待收货订单 -->
          <block wx:elif="{{item.status === '配送中' || item.status === '待取货'}}">
            <button class="op-btn detail-btn" bindtap="viewDetail" data-orderid="{{item.orderId}}">查看详情</button>
            <button class="op-btn pay-btn" bindtap="confirmReceive" data-orderid="{{item.orderId}}">确认收货</button>
          </block>
          <!-- 其他状态 -->
          <block wx:else>
            <button class="op-btn detail-btn" bindtap="viewDetail" data-orderid="{{item.orderId}}">查看详情</button>
          </block>
        </view>
      </view>
    </view>
  </view>
</view>
