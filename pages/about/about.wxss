page {
  background-color: #f5f5f5;
  padding: 0;
  margin: 0;
  box-sizing: border-box;
}

.about-container {
  width: 100%;
  min-height: 100vh;
  position: relative;
}

/* 顶部渐变背景 */
.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 420rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  overflow: hidden;
  z-index: 0;
}

.deco-circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
}

.deco-circle-1 {
  width: 280rpx;
  height: 280rpx;
  top: -100rpx;
  right: -80rpx;
}

.deco-circle-2 {
  width: 200rpx;
  height: 200rpx;
  bottom: -70rpx;
  left: -60rpx;
}

.deco-circle-3 {
  width: 150rpx;
  height: 150rpx;
  top: 80rpx;
  left: 120rpx;
}

/* 小程序信息 */
.about-info {
  position: relative;
  z-index: 10;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0 60rpx;
}

.logo-wrapper {
  position: relative;
  margin-bottom: 24rpx;
}

.about-logo {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.2);
  background: #fff;
}

.logo-badge {
  position: absolute;
  bottom: 5rpx;
  right: 5rpx;
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #ffd700 0%, #ffed4e 100%);
  border-radius: 50%;
  border: 4rpx solid #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.badge-icon {
  font-size: 24rpx;
  line-height: 1;
}

.app-name {
  font-size: 40rpx;
  color: #fff;
  font-weight: bold;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.app-slogan {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 20rpx;
}

.version-tag {
  padding: 8rpx 24rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 24rpx;
  backdrop-filter: blur(10rpx);
}

.version-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.95);
  font-weight: 500;
}

/* 联系我们卡片 */
.contact-card {
  margin: -30rpx 30rpx 30rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
  position: relative;
  z-index: 20;
}

.card-title {
  display: flex;
  align-items: center;
  padding: 30rpx 30rpx 20rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  border-bottom: 1rpx solid #f5f5f5;
}

.title-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.contact-list {
  padding: 0;
}

.contact-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
  transition: background 0.3s;
}

.contact-item:last-child {
  border-bottom: none;
}

.contact-item:active {
  background: #f8f9fa;
}

.contact-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.contact-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.contact-label {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.contact-right {
  display: flex;
  align-items: center;
}

.contact-value {
  font-size: 28rpx;
  color: #666;
  margin-right: 12rpx;
  max-width: 400rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.contact-arrow {
  font-size: 40rpx;
  color: #ccc;
  font-weight: 300;
  line-height: 1;
}

/* 应用介绍卡片 */
.intro-card {
  margin: 0 30rpx 30rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
}

.intro-content {
  padding: 30rpx;
}

.intro-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  text-align: justify;
}

/* 版权信息 */
.copyright {
  text-align: center;
  padding: 40rpx 30rpx;
  font-size: 24rpx;
  color: #999;
}