/* ========== 全局容器 ========== */
.cart-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #f5f7fa 0%, #fff 100%);
  position: relative;
}

/* ========== 顶部渐变背景 ========== */
.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 400rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 0 0 50rpx 50rpx;
  overflow: hidden;
}

.deco-circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
}

.deco-circle-1 {
  width: 300rpx;
  height: 300rpx;
  top: -100rpx;
  right: -50rpx;
}

.deco-circle-2 {
  width: 200rpx;
  height: 200rpx;
  bottom: -50rpx;
  left: 30rpx;
}

/* ========== 页面标题 ========== */
.page-title {
  position: relative;
  padding: 80rpx 40rpx 60rpx;
  text-align: center;
  z-index: 10;
}

.title-text {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
  letter-spacing: 4rpx;
}

.title-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  letter-spacing: 2rpx;
}

/* ========== 空购物车状态 ========== */
.empty-cart {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  padding: 100rpx 0;
  position: relative;
  z-index: 10;
}

.empty-icon {
  font-size: 120rpx;
  opacity: 0.8;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
  font-weight: 500;
}

.empty-hint {
  font-size: 26rpx;
  color: #bbb;
}

.go-shop {
  margin-top: 40rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border: none;
  padding: 20rpx 80rpx;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
}

/* ========== 购物车列表 ========== */
.cart-list {
  flex: 1;
  padding: 0 0 24rpx;
  overflow: hidden;
  position: relative;
  z-index: 10;
}

.cart-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  background: #fff;
  border-radius: 0;
  box-shadow: 0 2rpx 16rpx rgba(102, 126, 234, 0.1);
  transition: all 0.3s ease;
}

.cart-item:active {
  transform: scale(0.98);
}

.goods-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 16rpx;
  object-fit: cover;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.goods-img-placeholder {
  display: none;
}

.cart-item .goods-info {
  flex: 1;
  min-width: 0;
  overflow: hidden;
}

.cart-item .goods-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.price-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.cart-item .price {
  font-size: 36rpx;
  color: #e63946;
  font-weight: bold;
}

.stock-tip {
  font-size: 22rpx;
  color: #ff8c00;
  padding: 4rpx 12rpx;
  background: rgba(255, 140, 0, 0.1);
  border-radius: 12rpx;
}

/* ========== 数量控制按钮 ========== */
.num-control {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  gap: 8rpx;
}

.num-control .btn-minus,
.num-control .btn-plus {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
  transition: all 0.2s ease;
}

.num-control .btn-minus:active,
.num-control .btn-plus:active {
  transform: scale(0.9);
  opacity: 0.8;
}

.num-control .btn-minus.disabled,
.num-control .btn-plus.disabled {
  background: #e0e0e0;
  box-shadow: none;
}

.num-control .btn-icon {
  color: #fff;
  font-size: 40rpx;
  font-weight: 300;
  line-height: 1;
}

.num-control .btn-minus.disabled .btn-icon,
.num-control .btn-plus.disabled .btn-icon {
  color: #999;
}

.num-control .num-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  min-width: 60rpx;
  text-align: center;
}

/* ========== 删除按钮 ========== */
.del-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border-radius: 50%;
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a5a 100%);
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.3);
  transition: all 0.2s ease;
}

.del-btn:active {
  transform: scale(0.9);
  opacity: 0.8;
}

.del-btn .del-icon {
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
  line-height: 1;
}

/* ========== 底部结算栏 ========== */
.cart-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 30rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  border-top: none;
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
  position: sticky;
  bottom: 0;
  z-index: 100;
}

.footer-left {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.total-price {
  font-size: 28rpx;
  color: #666;
}

.total-price .price {
  color: #e63946;
  font-size: 40rpx;
  font-weight: bold;
}

/* 起送价提示 */
.min-order-tip {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  display: inline-block;
  font-weight: 500;
}

.min-order-tip.not-enough {
  color: #ff8c00;
  background: rgba(255, 140, 0, 0.15);
}

.min-order-tip.enough {
  color: #52c41a;
  background: rgba(82, 196, 26, 0.15);
}

.pay-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border: none;
  padding: 24rpx 60rpx;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
  touch-action: manipulation;
}

.pay-btn.disabled {
  background: #e0e0e0;
  color: #999;
  box-shadow: none;
}

/* ========== 订单操作栏样式 ========== */
.order-action-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 30rpx;
  z-index: 100;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
}

.order-action-bar .order-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.order-action-bar .order-text {
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
}

.order-action-bar .order-price {
  color: #fff;
  font-size: 40rpx;
  font-weight: bold;
}

.order-action-bar .order-btns {
  display: flex;
  gap: 20rpx;
}

.order-action-bar .btn-cancel {
  flex: 1;
  background-color: rgba(255, 255, 255, 0.2);
  color: #fff;
  border: 2rpx solid #fff;
  border-radius: 50rpx;
  font-size: 28rpx;
  padding: 16rpx 0;
  font-weight: 500;
}

.order-action-bar .btn-pay {
  flex: 1;
  background-color: #fff;
  color: #667eea;
  border: none;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: bold;
  padding: 16rpx 0;
}
