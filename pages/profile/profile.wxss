/* 页面容器 */
.profile-container {
  width: 100%;
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 40rpx;
  box-sizing: border-box;
  position: relative;
}

/* 顶部渐变背景 */
.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 380rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  overflow: hidden;
  z-index: 0;
}

.deco-circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
}

.deco-circle-1 {
  width: 250rpx;
  height: 250rpx;
  top: -80rpx;
  right: -60rpx;
}

.deco-circle-2 {
  width: 180rpx;
  height: 180rpx;
  bottom: -60rpx;
  left: -50rpx;
}

/* 头像区域 */
.avatar-section {
  position: relative;
  z-index: 10;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0 40rpx;
}

.avatar-wrapper {
  position: relative;
  margin-bottom: 20rpx;
}

.profile-avatar {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.2);
  background: #fff;
}

/* 头像编辑徽章 */
.avatar-edit-badge {
  position: absolute;
  bottom: 5rpx;
  right: 5rpx;
  width: 52rpx;
  height: 52rpx;
  background: linear-gradient(135deg, #ffd700 0%, #ffed4e 100%);
  border-radius: 50%;
  border: 4rpx solid #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.edit-icon {
  font-size: 28rpx;
  line-height: 1;
}

.user-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.change-avatar-tip {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  padding: 6rpx 20rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  backdrop-filter: blur(10rpx);
}

/* 信息卡片 */
.info-card {
  margin: -20rpx 30rpx 30rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
  position: relative;
  z-index: 20;
}

.card-title {
  padding: 30rpx 30rpx 20rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  border-bottom: 1rpx solid #f5f5f5;
}

/* 信息列表 */
.info-list {
  padding: 0;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
  transition: background 0.3s;
}

.info-item:last-child {
  border-bottom: none;
}

.info-item:active {
  background: #f8f9fa;
}

.info-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.info-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.info-label {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.info-right {
  display: flex;
  align-items: center;
}

.info-value {
  font-size: 28rpx;
  color: #999;
  margin-right: 12rpx;
  max-width: 400rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.info-arrow {
  font-size: 40rpx;
  color: #ccc;
  font-weight: 300;
  line-height: 1;
}

/* 保存按钮区域 */
.save-btn-wrap {
  padding: 0 30rpx;
  margin-top: 40rpx;
}

.save-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 48rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.save-btn-hover {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.save-icon {
  margin-right: 12rpx;
  font-size: 32rpx;
}

.save-text {
  font-size: 32rpx;
  color: #fff;
  font-weight: 600;
}

/* 生日选择器弹窗样式 */
.date-picker-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 999;
}

.modal-mask {
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  background-color: #fff;
  border-radius: 24rpx 24rpx 0 0;
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.cancel-btn,
.confirm-btn {
  font-size: 28rpx;
  color: #666;
  padding: 10rpx 20rpx;
}

.confirm-btn {
  color: #667eea;
  font-weight: 600;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.picker-body {
  padding: 0;
}

.date-picker-view {
  background: #fff;
}

.picker-item {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 50px;
  font-size: 32rpx;
  color: #333;
}

.selected-date {
  font-size: 36rpx;
  color: #333;
  font-weight: 500;
}