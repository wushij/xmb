/* ========== 全局容器 ========== */
.index-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 20rpx;
}

/* ========== 科幻风格头部横幅 ========== */
.banner-wrap {
  width: 100%;
  height: 280rpx;
  position: relative;
  border-radius: 16rpx;
  overflow: hidden;
  margin: 20rpx;
  margin-bottom: 30rpx;
  background: linear-gradient(135deg, #0a0e27 0%, #1a1f3a 50%, #0d1230 100%);
  box-shadow: 0 8rpx 32rpx rgba(0, 255, 255, 0.15);
  width: calc(100% - 40rpx);
}

/* 背景光效 */
.banner-bg-effect {
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(0, 255, 255, 0.1) 0%, transparent 70%);
  animation: bgRotate 8s linear infinite;
  z-index: 0;
}

.banner-bg-delay {
  animation-delay: -4s;
  opacity: 0.5;
}

@keyframes bgRotate {
  0% {
    transform: rotate(0deg);
  }
  100% {
    transform: rotate(360deg);
  }
}

/* 内容区 */
.banner-content {
  position: relative;
  z-index: 10;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 0 40rpx;
}

.banner-title {
  text-align: center;
  margin-bottom: 30rpx;
}

.title-main {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  text-shadow: 0 0 20rpx rgba(0, 255, 255, 0.5), 0 0 40rpx rgba(0, 255, 255, 0.3);
  letter-spacing: 8rpx;
  margin-bottom: 8rpx;
}

.title-sub {
  display: block;
  font-size: 20rpx;
  color: rgba(0, 255, 255, 0.8);
  letter-spacing: 12rpx;
  font-weight: 300;
}

/* 统计数据 */
.banner-stats {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 30rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 32rpx;
  font-weight: bold;
  color: #00ffff;
  text-shadow: 0 0 10rpx rgba(0, 255, 255, 0.6);
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: linear-gradient(to bottom, transparent, rgba(0, 255, 255, 0.5), transparent);
}

/* 装饰角标 */
.corner-deco {
  position: absolute;
  width: 30rpx;
  height: 30rpx;
  z-index: 20;
}

.corner-deco::before,
.corner-deco::after {
  content: '';
  position: absolute;
  background: #00ffff;
  box-shadow: 0 0 10rpx #00ffff, 0 0 20rpx #00ffff;
}

.corner-tl {
  top: 12rpx;
  left: 12rpx;
}
.corner-tl::before {
  width: 20rpx;
  height: 2rpx;
  top: 0;
  left: 0;
}
.corner-tl::after {
  width: 2rpx;
  height: 20rpx;
  top: 0;
  left: 0;
}

.corner-tr {
  top: 12rpx;
  right: 12rpx;
}
.corner-tr::before {
  width: 20rpx;
  height: 2rpx;
  top: 0;
  right: 0;
}
.corner-tr::after {
  width: 2rpx;
  height: 20rpx;
  top: 0;
  right: 0;
}

.corner-bl {
  bottom: 12rpx;
  left: 12rpx;
}
.corner-bl::before {
  width: 20rpx;
  height: 2rpx;
  bottom: 0;
  left: 0;
}
.corner-bl::after {
  width: 2rpx;
  height: 20rpx;
  bottom: 0;
  left: 0;
}

.corner-br {
  bottom: 12rpx;
  right: 12rpx;
}
.corner-br::before {
  width: 20rpx;
  height: 2rpx;
  bottom: 0;
  right: 0;
}
.corner-br::after {
  width: 2rpx;
  height: 20rpx;
  bottom: 0;
  right: 0;
}

/* 科技线条 */
.tech-line {
  position: absolute;
  background: linear-gradient(90deg, transparent, rgba(0, 255, 255, 0.6), transparent);
  z-index: 15;
}

.tech-line-1 {
  top: 50rpx;
  left: 0;
  width: 100%;
  height: 1rpx;
  animation: lineMove1 3s ease-in-out infinite;
}

.tech-line-2 {
  top: 100rpx;
  left: 0;
  width: 100%;
  height: 1rpx;
  animation: lineMove2 4s ease-in-out infinite;
  animation-delay: 1s;
}

.tech-line-3 {
  bottom: 50rpx;
  left: 0;
  width: 100%;
  height: 1rpx;
  animation: lineMove3 3.5s ease-in-out infinite;
  animation-delay: 0.5s;
}

@keyframes lineMove1 {
  0%, 100% {
    opacity: 0.3;
    transform: scaleX(0.5);
  }
  50% {
    opacity: 1;
    transform: scaleX(1);
  }
}

@keyframes lineMove2 {
  0%, 100% {
    opacity: 0.5;
    transform: scaleX(0.7);
  }
  50% {
    opacity: 0.8;
    transform: scaleX(0.9);
  }
}

@keyframes lineMove3 {
  0%, 100% {
    opacity: 0.4;
    transform: scaleX(0.6);
  }
  50% {
    opacity: 1;
    transform: scaleX(1);
  }
}

/* ========== 商品分类卡片 ========== */
.cate-section {
  background: #fff;
  margin: 0 20rpx 24rpx;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 6rpx 24rpx rgba(102, 126, 234, 0.12);
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.section-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

/* 专区入口 */
.cate-entry {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.cate-item {
  width: 33.33%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
}

.cate-icon-wrap {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #f0f3ff 0%, #e8ecff 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.15);
  transition: all 0.3s;
}

.cate-item:active .cate-icon-wrap {
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.2);
}

.cate-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  object-fit: cover;
}

.cate-name {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

/* ========== 热销推荐卡片 ========== */
.hot-goods-section {
  background: #fff;
  margin: 0 20rpx 24rpx;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 6rpx 24rpx rgba(102, 126, 234, 0.12);
}

.hot-goods-list {
  margin-top: 8rpx;
}

/* 图片加载失败时的兜底占位符 */
.cate-icon-placeholder {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #666;
}

/* ========== 查看更多提示 ========== */
.view-more-wrap {
  margin-top: 32rpx;
  padding-top: 32rpx;
  border-top: 2rpx dashed #eee;
  position: relative;
  overflow: hidden;
}

.view-more-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: linear-gradient(135deg, #f8f9ff 0%, #f0f3ff 100%);
  border-radius: 16rpx;
  border: 2rpx dashed rgba(102, 126, 234, 0.3);
}

.view-more-text {
  font-size: 28rpx;
  color: #666;
}

.view-more-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 12rpx 28rpx;
  border-radius: 30rpx;
  color: #fff;
  font-size: 26rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.view-more-btn .arrow-icon {
  font-size: 24rpx;
  margin-left: 4rpx;
}

.view-more-deco {
  position: absolute;
  right: -30rpx;
  bottom: -30rpx;
  width: 120rpx;
  height: 120rpx;
  background: rgba(102, 126, 234, 0.05);
  border-radius: 50%;
}
