<view class="index-container">
  <!-- 科幻风格头部横幅 -->
  <view class="banner-wrap">
    <!-- 背景光效 -->
    <view class="banner-bg-effect"></view>
    <view class="banner-bg-effect banner-bg-delay"></view>
    
    <!-- 内容区 -->
    <view class="banner-content">
      <view class="banner-title">
        <text class="title-main">校园小卖部</text>
        <text class="title-sub">CAMPUS STORE</text>
      </view>
      <view class="banner-stats">
        <view class="stat-item">
          <text class="stat-num">100+</text>
          <text class="stat-label">精选商品</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-num">24h</text>
          <text class="stat-label">在线服务</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-num">极速</text>
          <text class="stat-label">配送到达</text>
        </view>
      </view>
    </view>
    
    <!-- 装饰元素 -->
    <view class="corner-deco corner-tl"></view>
    <view class="corner-deco corner-tr"></view>
    <view class="corner-deco corner-bl"></view>
    <view class="corner-deco corner-br"></view>
    
    <!-- 科技线条 -->
    <view class="tech-line tech-line-1"></view>
    <view class="tech-line tech-line-2"></view>
    <view class="tech-line tech-line-3"></view>
  </view>

  <!-- 6个专区入口卡片 -->
  <view class="cate-section">
    <view class="section-header">
      <text class="section-icon">📦</text>
      <text class="section-title">商品分类</text>
    </view>
    <view class="cate-entry">
      <view class="cate-item" wx:for="{{cateList}}" wx:key="id" bindtap="goCategory" data-cateid="{{item.cateId}}">
        <view class="cate-icon-wrap">
          <image 
            class="cate-icon"  
            src="{{item.imgUrl}}" 
            mode="aspectFill"
            binderror="onCateImgError"  
            data-index="{{index}}"   
          ></image>
        </view>
        <text class="cate-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- 热销推荐卡片 -->
  <view class="hot-goods-section">
    <view class="section-header">
      <text class="section-icon">🔥</text>
      <text class="section-title">热销推荐</text>
    </view>
    <view class="hot-goods-list">
      <goods-item 
        wx:for="{{hotGoodsList}}" 
        wx:key="goodsId" 
        goods="{{item}}"
        bind:cartChange="cartChange"
      ></goods-item>
    </view>
    
    <!-- 查看更多提示 -->
    <view class="view-more-wrap" bindtap="goToCategory">
      <view class="view-more-content">
        <text class="view-more-text">更多精彩商品等你发现</text>
        <view class="view-more-btn">
          <text>去逛逛</text>
          <text class="arrow-icon">→</text>
        </view>
      </view>
      <view class="view-more-deco"></view>
    </view>
  </view>
</view>