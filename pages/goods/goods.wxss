/* ========== 全局容器 ========== */
.goods-detail {
  padding-bottom: 120rpx;
  background: linear-gradient(180deg, #f5f7fa 0%, #fff 100%);
  min-height: 100vh;
}

/* ========== 商品图片区域 ========== */
.goods-img-wrap {
  width: 100%;
  height: 600rpx;
  background-color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.goods-img {
  width: 100%;
  height: 100%;
}

.goods-img-placeholder {
  width: 100%;
  height: 600rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 48rpx;
  font-weight: bold;
  text-align: center;
  padding: 40rpx;
  box-sizing: border-box;
}

/* ========== 商品信息卡片 ========== */
.goods-info-card {
  background: #fff;
  padding: 32rpx;
  margin: 24rpx;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.12);
  position: relative;
}

.goods-name {
  font-size: 38rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  line-height: 1.5;
}

.price-section {
  display: flex;
  align-items: flex-end;
  gap: 20rpx;
  margin-bottom: 20rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #f8f9ff 0%, #fff 100%);
  border-radius: 16rpx;
  border: 2rpx solid rgba(102, 126, 234, 0.2);
}

.price-main {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.price-label {
  font-size: 24rpx;
  color: #999;
}

.now-price {
  font-size: 56rpx;
  color: #e63946;
  font-weight: bold;
  line-height: 1;
}

.old-price-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.old-price {
  font-size: 28rpx;
  color: #999;
  text-decoration: line-through;
}

.discount-tag {
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a5a 100%);
  color: #fff;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-weight: 500;
}

.stock-section {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.stock-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 28rpx;
  color: #666;
}

.stock-icon {
  font-size: 32rpx;
}

.low-stock {
  font-size: 24rpx;
  color: #ff8c00;
  padding: 6rpx 16rpx;
  background: rgba(255, 140, 0, 0.15);
  border-radius: 12rpx;
  font-weight: 500;
}

/* ========== 商品详情描述卡片 ========== */
.goods-desc-card {
  background: #fff;
  padding: 32rpx;
  margin: 0 24rpx 24rpx;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.12);
}

.card-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.title-icon {
  font-size: 36rpx;
}

.desc-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}

/* ========== 底部操作栏 ========== */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 110rpx;
  background: #fff;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  padding-bottom: env(safe-area-inset-bottom);
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
  box-sizing: border-box;
  z-index: 100;
}

.cart-icon {
  position: relative;
  width: 100rpx;
  text-align: center;
  font-size: 48rpx;
  padding: 10rpx;
}

.cart-num {
  position: absolute;
  top: 0;
  right: 10rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 22rpx;
  min-width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  border-radius: 18rpx;
  text-align: center;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.4);
}

.add-cart-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: linear-gradient(135deg, #ffa500 0%, #ff8c00 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 40rpx;
  margin-left: 20rpx;
  box-shadow: 0 6rpx 20rpx rgba(255, 165, 0, 0.3);
}

.buy-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 40rpx;
  margin-left: 20rpx;
  box-shadow: 0 6rpx 20rpx rgba(102, 126, 234, 0.4);
}
