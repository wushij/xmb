/* ========== 页面容器 ========== */
.page-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  background: #fff;
  position: relative;
}

/* ========== 顶部渐变背景 ========== */
.header-bg {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 280rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 0 0 50rpx 50rpx;
  overflow: hidden;
  z-index: 100;
}

.deco-circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
}

.deco-circle-1 {
  width: 250rpx;
  height: 250rpx;
  top: -80rpx;
  right: -60rpx;
}

.deco-circle-2 {
  width: 150rpx;
  height: 150rpx;
  bottom: -40rpx;
  left: 20rpx;
}

/* ========== 搜索卡片 ========== */
.search-card {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 101;
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  margin-top: 60rpx;
  margin-left: 20rpx;
  margin-right: 20rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 6rpx 24rpx rgba(102, 126, 234, 0.15);
}

.search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #f5f7fa 0%, #fff 100%);
  border-radius: 50rpx;
  padding: 0 20rpx;
  height: 72rpx;
  margin-right: 15rpx;
  position: relative;
  border: 2rpx solid #f0f0f0;
  transition: all 0.3s;
}

.search-input-wrap:focus-within {
  border-color: #667eea;
  background: #fff;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.15);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  height: 100%;
  font-size: 28rpx;
  padding: 0 10rpx;
  color: #333;
}

.clear-icon {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #999;
  z-index: 10;
  background: #f0f0f0;
  border-radius: 50%;
}

.search-btn {
  width: 120rpx;
  height: 72rpx;
  line-height: 72rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: 500;
  padding: 0;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.3);
}

.search-btn:active {
  transform: scale(0.98);
}

/* ========== 免配送费提示 ========== */
.free-delivery-tip {
  position: fixed;
  top: 200rpx;
  left: 20rpx;
  right: 20rpx;
  z-index: 102;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 24rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50rpx;
  backdrop-filter: blur(10px);
}

.free-delivery-tip .free-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.free-delivery-tip .free-text {
  font-size: 26rpx;
  color: #fff;
  font-weight: 500;
}

/* ========== 分类容器 ========== */
.category-container {
  flex: 1;
  display: flex;
  margin-top: 280rpx;
  height: calc(100vh - 280rpx);
  position: relative;
  z-index: 10;
}

/* ========== 左侧分类栏 ========== */
.category-left {
  width: 180rpx;
  background: #fff;
  height: 100%;
  padding: 16rpx 0;
  box-shadow: 4rpx 0 16rpx rgba(0, 0, 0, 0.04);
  flex-shrink: 0;
}

.category-item {
  height: 100rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #666;
  border-left: 6rpx solid transparent;
  transition: all 0.3s;
  margin: 8rpx 0;
  padding: 10rpx 8rpx;
  position: relative;
}

.cate-img {
  width: 48rpx;
  height: 48rpx;
  border-radius: 8rpx;
  margin-bottom: 6rpx;
  flex-shrink: 0;
}

.cate-name {
  font-size: 24rpx;
  transition: all 0.3s;
}

.category-item.active {
  background: linear-gradient(90deg, rgba(102, 126, 234, 0.1) 0%, transparent 100%);
  border-left-color: #667eea;
}

.category-item.active .cate-name {
  color: #667eea;
  font-weight: 600;
}

/* ========== 右侧商品栏 ========== */
.category-right {
  flex: 1;
  padding: 16rpx;
  height: 100%;
  box-sizing: border-box;
  background: #fff;
}

/* ========== 免配送费卡片（已移到顶部，保留样式以防需要） ========== */
.free-delivery-card {
  display: none;
}

/* ========== 商品列表布局 ========== */
.goods-list {
  display: block;
  width: 100%;
}

/* 不覆盖goods-item组件的样式，保持后端图片显示 */

/* ========== 空状态 ========== */
.empty-tip {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}
